{
  "name": "prompt-rules-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "dev:server": "tsx watch server/index.ts",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.server.json --noEmit",
    "build": "npm run typecheck && tsc -p tsconfig.server.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start:server": "node dist-server/server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^8.0.11"
  }
}
